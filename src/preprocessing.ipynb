import pandas as pd
import ast

def load_data(movies_path: str, credits_path: str) -> pd.DataFrame:
    """Load and merge the TMDB movies and credits CSVs."""
    movies = pd.read_csv(movies_path)
    credits = pd.read_csv(credits_path)

    # Merge on title
    df = movies.merge(credits, on="title")
    return df


def extract_genres(genres_str: str) -> str:
    """Convert genres JSON string → space-separated genre names."""
    try:
        genres = ast.literal_eval(genres_str)
        return " ".join([g["name"] for g in genres])
    except:
        return ""


def clean_overview(text: str) -> str:
    """Strip whitespace, handle missing overviews."""
    if pd.isna(text):
        return ""
    return text.strip()


def build_combined_features(df: pd.DataFrame) -> pd.DataFrame:
    """
    Create a single 'combined' column merging:
    title + genres + overview
    This is what we'll convert to embeddings.
    """
    df = df[["title", "genres", "overview"]].copy()

    df["genres_clean"] = df["genres"].apply(extract_genres)
    df["overview_clean"] = df["overview"].apply(clean_overview)

    # Combine all text features into one string per movie
    df["combined"] = (
        df["title"] + " "
        + df["genres_clean"] + " "
        + df["overview_clean"]
    )

    # Drop rows where combined is mostly empty
    df = df[df["combined"].str.len() > 20].reset_index(drop=True)

    return df[["title", "genres_clean", "overview_clean", "combined"]]


def preprocess(movies_path: str, credits_path: str) -> pd.DataFrame:
    """Full pipeline: load → clean → combine."""
    print("📦 Loading data...")
    df = load_data(movies_path, credits_path)

    print("🧹 Cleaning and combining features...")
    df = build_combined_features(df)

    print(f"✅ Done! {len(df)} movies ready.")
    return df


# Quick test — run this file directly to verify
if __name__ == "__main__":
